  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
