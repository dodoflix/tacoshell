{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tacoshell",
  "version": "0.1.0",
  "identifier": "app.tacoshell",
  "build": {
    "beforeDevCommand": "pnpm vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tacoshell",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
